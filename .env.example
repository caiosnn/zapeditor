# Chave da API do OpenRouter (pegue em https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Modelo multimodal usado para transcrever (curtos) e corrigir. Precisa aceitar áudio.
#   google/gemini-2.5-flash        -> recomendado (qualidade + custo)
#   google/gemini-2.5-flash-lite   -> mais barato
OPENROUTER_MODEL=google/gemini-2.5-flash

# Idioma esperado (pt, en, es...). Vazio = detecção automática.
TRANSCRIBE_LANGUAGE=pt

# Formato da transcrição: srt (com timestamps) | plain (texto corrido)
OUTPUT_FORMAT=srt

# Quando o bot age:
# auto    = transcreve tudo automaticamente
# mention = em grupos só quando marcarem o bot (@); no privado, direto  [recomendado]
# command = só quando responderem a uma mídia com !transcrever
TRANSCRIBE_MODE=mention

# Limite de duração (s). 0 = sem limite (vídeos longos vão pro Whisper local em pedaços).
MAX_DURATION_SECONDS=0

# Modelo do Whisper local (faster-whisper) p/ legenda e vídeos longos: tiny|base|small|medium
WHISPER_MODEL=small

# Executável do Python (caso não seja "python" no PATH)
PYTHON_BIN=python

# ===== Especialista de IA / Higgsfield (geração de imagem e vídeo) =====
# Pré-requisitos: npm install -g @higgsfield/cli  +  higgsfield auth login

# Liga/desliga o agente especialista (true|false)
EXPERT_ENABLED=true
# Modelo do OpenRouter que raciocina como especialista (vazio = usa OPENROUTER_MODEL)
# meta-llama/llama-4-maverick = permissivo c/ pessoas/clientes, mas barra deepfake difamatório (recomendado)
# qwen/qwen3-235b-a22b-2507 = idem, mais barato | openai/gpt-5.1-chat = mais conservador
EXPERT_MODEL=meta-llama/llama-4-maverick
# Caminho do entry-point do CLI higgsfield (vazio = auto-detecta no npm global)
# HIGGSFIELD_ENTRY=
# Modelos padrão de geração (job_set_type do Higgsfield)
HF_IMAGE_MODEL=nano_banana_2
HF_VIDEO_MODEL=veo3_1
# Parâmetros padrão
HF_IMAGE_RESOLUTION=2k       # 1k | 2k | 4k
HF_VIDEO_DURATION=8          # 4 | 6 | 8 (segundos)
HF_VIDEO_QUALITY=basic       # basic | high | ultra
# Confirmar custo antes de gerar VÍDEO (imagem é barata e vai direto)
HF_CONFIRM_VIDEO=true

# Enviar toda mídia (legenda/corte/geração) também como DOCUMENTO, em qualidade
# original (sem a recompressão do WhatsApp). true|false
SEND_ORIGINAL_DOC=true

# ===== Media downloader (yt-dlp + gallery-dl + instaloader) =====
# Marcar o bot (ou mandar no privado) num link de YouTube/X/Instagram/TikTok
# baixa o vídeo/foto e reenvia no chat. Pré-requisitos no PATH:
#   yt-dlp + ffmpeg (vídeo de tudo, inclusive IG autenticado)
#   pip install gallery-dl    (foto pura de IG/X)
#   pip install instaloader   (fallback do IG público quando não há cookies)
# YouTube e TikTok funcionam sem configurar nada. Instagram e X precisam do cookies.txt (abaixo).
DOWNLOADER_ENABLED=true
# Caminhos dos binários (vazio = auto-detecta no PATH)
# YTDLP_PATH=
# GALLERYDL_PATH=
# INSTALOADER_PATH=
# Teto de qualidade/tamanho (perfil equilibrado)
DOWNLOAD_MAX_HEIGHT=1080        # resolução máx (1080 | 720 | 480)
DOWNLOAD_MAX_FILESIZE_MB=200    # ignora vídeos acima disso
DOWNLOAD_MAX_DURATION_SEC=1200  # ignora vídeos mais longos que isso (1200 = 20min)
DOWNLOAD_MAX_ITEMS=10           # máx de fotos por link (carrossel/galeria)

# --- Cookies do Instagram/X (é o que faz IG e X funcionarem) — CONFIGURA UMA VEZ ---
# IG e X exigem login pra quase tudo. O yt-dlp+cookies é o caminho ROBUSTO (não é
# bloqueado como o instaloader). Como gerar:
#   1) No navegador logado no IG, exporte os cookies com a extensão "Cookie-Editor"
#      (ou "Get cookies.txt LOCALLY") no formato Netscape.
#   2) Salve em auth/ig-cookies.txt (o mesmo arquivo serve pro X se logar no x.com também).
#   3) pm2 restart zapeditor
DOWNLOAD_COOKIES_FILE=C:/Users/Caio/Documents/Bot Whatsapp/auth/ig-cookies.txt
# Alternativa (NÃO funciona com o navegador aberto no Windows): puxar do navegador. chrome|edge|firefox
DOWNLOAD_COOKIES_BROWSER=

# --- Instagram via instaloader (fallback frágil; o IG bloqueia. Prefira o cookies.txt acima) ---
# INSTAGRAM_USER=
# INSTALOADER_SESSION=          # vazio = auth/instaloader/session-<INSTAGRAM_USER>
DOWNLOAD_COOKIES_BROWSER=

# ===== Arquivamento automático no Google Drive =====
# Sobe todo anexo (vídeo/imagem/áudio/doc) de um grupo pro Drive, organizado por
# dia e tipo. Pré-requisito: criar credencial OAuth "app para computador" no
# Google Cloud Console e rodar `npm run drive-auth` pra logar uma vez.

# Liga/desliga o arquivamento (true|false)
ARCHIVE_ENABLED=false
# Credenciais do OAuth (Google Cloud Console > Credenciais > ID do cliente OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Grupos a arquivar (JIDs separados por vírgula, ex: 120363012345678901@g.us)
ARCHIVE_GROUPS=
# Descobrir o JID dos grupos: deixe true, mande algo no grupo, veja no log
# "GRUPO: ... -> ARCHIVE_GROUPS=...", copie o JID e volte pra false.
ARCHIVE_DISCOVER=false
# Pasta raiz no Drive (organiza em subpastas por dia e por tipo)
ARCHIVE_ROOT_FOLDER=Edições WhatsApp

# ===== Interface web (gestão do arquivamento por grupo) =====
# Liga a interface web local (true|false). DEFINA UMA SENHA antes de ligar.
WEB_ENABLED=false
WEB_PORT=3333
WEB_PASSWORD=

# Números autorizados a gerenciar o arquivamento pelo WhatsApp (privado do bot),
# com DDI, separados por vírgula. Ex: 556199938020 . Vazio = só pela interface web.
ADMIN_NUMBERS=
